{{-- ── 3. SAMBUTAN / WELCOME CARD ── --}}
<section class="py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800/80 shadow-xl rounded-[3rem] overflow-hidden grid grid-cols-1 lg:grid-cols-12">
            
            {{-- Welcome Intro (Accent BG) --}}
            <div class="lg:col-span-4 bg-gradient-to-br from-primary to-teal-800 p-10 md:p-12 text-white flex flex-col justify-between relative overflow-hidden min-h-[320px] lg:min-h-full">
                <div class="absolute -right-20 -bottom-20 w-72 h-72 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
                <div class="absolute -left-10 -top-10 w-40 h-40 bg-teal-400/20 rounded-full blur-2xl pointer-events-none"></div>
                
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-white/10 border border-white/20 flex items-center justify-center mb-8 shadow-inner">
                        <span class="material-symbols-outlined text-[28px] text-white">handshake</span>
                    </div>
                    <div class="space-y-3">
                        <span class="inline-flex items-center px-3 py-1 rounded-full bg-white/10 text-white text-[9px] font-black uppercase tracking-wider border border-white/10">Sambutan</span>
                        <h3 class="text-2xl md:text-3xl font-black font-jakarta tracking-tight leading-tight">
                            Selamat Datang
                        </h3>
                        <p class="text-sm text-emerald-100/90 leading-relaxed font-semibold">
                            Posyandu ILP Kenanga RW 011 Kelurahan Aren Jaya.
                        </p>
                    </div>
                </div>

                <div class="relative z-10 pt-6 border-t border-white/10 text-[9px] font-black uppercase tracking-widest text-white/60">
                    Kelurahan Aren Jaya &bull; RW 011
                </div>
            </div>

            {{-- Welcome Text Body --}}
            <div class="lg:col-span-8 p-8 md:p-12 lg:p-14 flex flex-col justify-between gap-10">
                {{-- Intro Callout --}}
                <div class="relative pl-6 border-l-4 border-primary">
                    <p class="text-slate-900 dark:text-slate-100 font-extrabold text-lg md:text-xl leading-relaxed font-jakarta">
                        Posyandu ILP Kenanga RW 011 hadir sebagai wujud komitmen masyarakat dalam meningkatkan kualitas kesehatan warga melalui pelayanan kesehatan primer yang terpadu, mudah diakses, dan berkelanjutan.
                    </p>
                </div>

                {{-- Pillars Grid --}}
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    
                    {{-- Pilar 1: Sasaran & Lokasi --}}
                    <div class="relative overflow-hidden bg-slate-50/50 dark:bg-slate-900/30 border border-slate-100 dark:border-slate-800/80 p-6 md:p-8 rounded-[2rem] transition-all duration-300 hover:shadow-lg hover:shadow-slate-100/50 dark:hover:shadow-none hover:-translate-y-1 flex flex-col justify-between group">
                        <div class="absolute right-4 top-4 text-5xl font-black text-slate-100 dark:text-slate-800/60 select-none pointer-events-none z-0">01</div>
                        <div class="relative z-10 flex flex-col justify-between h-full gap-6">
                            <div class="space-y-4">
                                <div class="w-12 h-12 bg-teal-50 dark:bg-teal-950/40 text-teal-600 dark:text-teal-400 border border-teal-100 dark:border-teal-900/50 rounded-xl flex items-center justify-center">
                                    <span class="material-symbols-outlined text-[24px]">location_on</span>
                                </div>
                                <h4 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">Wilayah &amp; Sasaran</h4>
                                <p class="text-xs md:text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-medium">
                                    Melayani seluruh lapisan masyarakat di Kelurahan Aren Jaya secara terpadu di lingkup RW 011.
                                </p>
                            </div>
                            <div class="flex flex-wrap gap-1.5 mt-auto">
                                <span class="inline-flex items-center px-2 py-1 rounded bg-teal-50/60 dark:bg-teal-950/20 text-teal-700 dark:text-teal-400 text-[9px] font-bold border border-teal-100/40 dark:border-teal-900/40">🤰 Ibu Hamil</span>
                                <span class="inline-flex items-center px-2 py-1 rounded bg-teal-50/60 dark:bg-teal-950/20 text-teal-700 dark:text-teal-400 text-[9px] font-bold border border-teal-100/40 dark:border-teal-900/40">👶 Balita</span>
                                <span class="inline-flex items-center px-2 py-1 rounded bg-teal-50/60 dark:bg-teal-950/20 text-teal-700 dark:text-teal-400 text-[9px] font-bold border border-teal-100/40 dark:border-teal-900/40">🧒 Remaja</span>
                                <span class="inline-flex items-center px-2 py-1 rounded bg-teal-50/60 dark:bg-teal-950/20 text-teal-700 dark:text-teal-400 text-[9px] font-bold border border-teal-100/40 dark:border-teal-900/40">🧑 Dewasa</span>
                                <span class="inline-flex items-center px-2 py-1 rounded bg-teal-50/60 dark:bg-teal-950/20 text-teal-700 dark:text-teal-400 text-[9px] font-bold border border-teal-100/40 dark:border-teal-900/40">🧓 Lansia</span>
                            </div>
                        </div>
                    </div>

                    {{-- Pilar 2: Layanan ILP & Kader --}}
                    <div class="relative overflow-hidden bg-slate-50/50 dark:bg-slate-900/30 border border-slate-100 dark:border-slate-800/80 p-6 md:p-8 rounded-[2rem] transition-all duration-300 hover:shadow-lg hover:shadow-slate-100/50 dark:hover:shadow-none hover:-translate-y-1 flex flex-col justify-between group">
                        <div class="absolute right-4 top-4 text-5xl font-black text-slate-100 dark:text-slate-800/60 select-none pointer-events-none z-0">02</div>
                        <div class="relative z-10 flex flex-col justify-between h-full gap-6">
                            <div class="space-y-4">
                                <div class="w-12 h-12 bg-indigo-50 dark:bg-indigo-950/40 text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/50 rounded-xl flex items-center justify-center">
                                    <span class="material-symbols-outlined text-[24px]">volunteer_activism</span>
                                </div>
                                <h4 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">Integrasi Layanan</h4>
                                <p class="text-xs md:text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-medium">
                                    Fokus pada pencegahan penyakit, promosi kesehatan, pemantauan tumbuh kembang, dan deteksi dini risiko medis terintegrasi.
                                </p>
                            </div>
                            <div class="flex flex-wrap gap-1.5 mt-auto">
                                <span class="inline-flex items-center px-2.5 py-1 rounded bg-indigo-50/60 dark:bg-indigo-950/20 text-indigo-700 dark:text-indigo-400 text-[9px] font-bold border border-indigo-100/40 dark:border-indigo-900/40">🛡️ Pencegahan</span>
                                <span class="inline-flex items-center px-2.5 py-1 rounded bg-indigo-50/60 dark:bg-indigo-950/20 text-indigo-700 dark:text-indigo-400 text-[9px] font-bold border border-indigo-100/40 dark:border-indigo-900/40">❤️ Promosi</span>
                            </div>
                        </div>
                    </div>

                    {{-- Pilar 3: Portal Digital --}}
                    <div class="relative overflow-hidden bg-slate-50/50 dark:bg-slate-900/30 border border-slate-100 dark:border-slate-800/80 p-6 md:p-8 rounded-[2rem] transition-all duration-300 hover:shadow-lg hover:shadow-slate-100/50 dark:hover:shadow-none hover:-translate-y-1 flex flex-col justify-between group">
                        <div class="absolute right-4 top-4 text-5xl font-black text-slate-100 dark:text-slate-800/60 select-none pointer-events-none z-0">03</div>
                        <div class="relative z-10 flex flex-col justify-between h-full gap-6">
                            <div class="space-y-4">
                                <div class="w-12 h-12 bg-amber-50 dark:bg-amber-950/40 text-amber-600 dark:text-amber-400 border border-amber-100 dark:border-amber-900/50 rounded-xl flex items-center justify-center">
                                    <span class="material-symbols-outlined text-[24px]">campaign</span>
                                </div>
                                <h4 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">Portal Digital</h4>
                                <p class="text-xs md:text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-medium">
                                    Website ini kami hadirkan sebagai media informasi terintegrasi bagi warga RW 011 Aren Jaya untuk memantau rekam data posyandu secara transparan.
                                </p>
                            </div>
                            <div class="flex flex-wrap gap-1.5 mt-auto">
                                <span class="inline-flex items-center px-2 py-1 rounded bg-amber-50/60 dark:bg-amber-950/20 text-amber-700 dark:text-amber-400 text-[9px] font-bold border border-amber-100/40 dark:border-amber-900/40">📅 Jadwal</span>
                                <span class="inline-flex items-center px-2 py-1 rounded bg-amber-50/60 dark:bg-amber-950/20 text-amber-700 dark:text-amber-400 text-[9px] font-bold border border-amber-100/40 dark:border-amber-900/40">📋 Program</span>
                                <span class="inline-flex items-center px-2 py-1 rounded bg-amber-50/60 dark:bg-amber-950/20 text-amber-700 dark:text-amber-400 text-[9px] font-bold border border-amber-100/40 dark:border-amber-900/40">📖 Edukasi</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
